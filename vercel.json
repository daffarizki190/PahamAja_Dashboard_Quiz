{
    "version": 2,
    "builds": [
        {
            "src": "api/**/*.php",
            "use": "vercel-php@0.7.4"
        }
    ],
    "routes": [
        {
            "src": "/api/info",
            "dest": "api/info.php"
        },
        {
            "src": "/(css|js|images|favicon.ico)(.*)",
            "dest": "public/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ]
}
