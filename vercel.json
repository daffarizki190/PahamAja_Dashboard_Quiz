{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php"
        }
    },
    "routes": [
        {
            "src": "/(css|js|images|favicon.ico)(.*)",
            "dest": "public/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ]
}
