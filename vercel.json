{
    "version": 2,
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        {
            "src": "/api/info",
            "dest": "api/info.php"
        },
        {
            "src": "/(css|js|images|favicon.ico)(.*)",
            "dest": "public/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ]
}
